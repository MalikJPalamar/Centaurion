{
  "runtime": "raspberry-pi",
  "agent": "Cortex",
  "skills": [
    "centaurion/skills/centaurion-core",
    "centaurion/skills/routing-gate",
    "centaurion/skills/sa-scan"
  ],
  "identity": {
    "repo": "centaurion",
    "load_on_start": [
      "identity/PURPOSE.md",
      "identity/MISSION.md",
