{
  "service": "supermemory",
  "description": "Layer 1: Shared memory bus — ambient, real-time capture and recall across all agents",
  "status": "connected",
  "tier": "free",
  "limits": {
    "tokens": "1M",
    "queries_per_month": "10K"
  },
  "apiKey": "${SUPERMEMORY_API_KEY}",
  "apiKeySource": "env:SUPERMEMORY_API_KEY",
  "apiKeyPath": "/root/Centaurion/.env (gitignored, 600 perms)",
  "firstLiveCapture": "2026-04-19T18:56:15Z",
  "firstLiveCaptureId": "PF1gaWe1rhggEJ6eLLwon8",
  "endpoints": {
    "write": "POST https://api.supermemory.ai/v3/documents",
    "search": "POST https://api.supermemory.ai/v3/search"
  },
  "verifiedRoundTrip": true,
  "containers": {
    "aob": "centaurion-aob",
    "builderbee": "centaurion-builderbee",
    "centaurion": "centaurion-framework",
    "personal": "centaurion-malik"
  },
  "autoRecall": true,
  "autoCapture": true,
  "plugins": {
    "claude_code": "supermemoryai/claude-supermemory",
    "openclaw": "@supermemory/openclaw-supermemory"
  },
  "notes": "Purpose: 'What was I working on 5 minutes ago?' Real-time shared bus across all agents and runtimes."
}
