{
  "service": "supermemory",
  "description": "Layer 1: Shared memory bus — ambient, real-time capture and recall across all agents",
  "tier": "free",
  "limits": {
    "tokens": "1M",
    "queries_per_month": "10K"
  },
  "apiKey": "REPLACE_WITH_SUPERMEMORY_API_KEY",
  "containers": {
    "aob": "centaurion-aob",
    "builderbee": "centaurion-builderbee",
    "centaurion": "centaurion-framework",
    "personal": "centaurion-malik"
  },
  "autoRecall": true,
  "autoCapture": true,
  "plugins": {
    "claude_code": "supermemoryai/claude-supermemory",
    "openclaw": "@supermemory/openclaw-supermemory"
  },
  "notes": "Purpose: 'What was I working on 5 minutes ago?' Real-time shared bus across all agents and runtimes."
}
